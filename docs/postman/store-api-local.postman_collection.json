{
  "info": {
    "name": "Store API - Local",
    "description": "Complete Postman collection for Store API local testing, including end-to-end checkout flow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "5f2bb6e2-01d6-4eb9-9f79-4e8c98a6d0d1"
  },
  "item": [
    {
      "name": "0 - Health & Docs",
      "item": [
        {
          "name": "Home",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/"
          }
        },
        {
          "name": "OpenAPI JSON",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v3/api-docs"
          }
        },
        {
          "name": "Swagger Redirect",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/swagger-ui.html"
          }
        }
      ]
    },
    {
      "name": "1 - Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 or 200', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Store userId', function () {",
                  "  var body = pm.response.json();",
                  "  if (body && body.id) pm.environment.set('userId', body.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Store access token', function () {",
                  "  var body = pm.response.json();",
                  "  if (body && body.token) pm.environment.set('accessToken', body.token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Current User (me)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/auth/refresh"
          }
        }
      ]
    },
    {
      "name": "2 - Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "Get Products By Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?categoryId=1",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [{ "key": "categoryId", "value": "1" }]
            }
          }
        },
        {
          "name": "Get Product By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "Create Product (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Gaming Mouse\",\n  \"description\": \"RGB mouse\",\n  \"price\": 59.99,\n  \"categoryId\": 1\n}"
            },
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "Update Product (ADMIN)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Gaming Mouse Pro\",\n  \"description\": \"Updated\",\n  \"price\": 79.99,\n  \"categoryId\": 1\n}"
            },
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "Delete Product (ADMIN)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        }
      ]
    },
    {
      "name": "3 - Carts",
      "item": [
        {
          "name": "Create Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Store cartId', function () {",
                  "  var body = pm.response.json();",
                  "  if (body && body.id) pm.environment.set('cartId', body.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/carts"
          }
        },
        {
          "name": "Add Item To Cart",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}}\n}"
            },
            "url": "{{baseUrl}}/carts/{{cartId}}/items"
          }
        },
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/carts/{{cartId}}"
          }
        },
        {
          "name": "Update Cart Item Quantity",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 2\n}"
            },
            "url": "{{baseUrl}}/carts/{{cartId}}/items/{{productId}}"
          }
        },
        {
          "name": "Remove Cart Item",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/carts/{{cartId}}/items/{{productId}}"
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/carts/{{cartId}}/items"
          }
        }
      ]
    },
    {
      "name": "4 - Checkout & Payments",
      "item": [
        {
          "name": "Checkout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Store orderId and checkoutUrl', function () {",
                  "  var body = pm.response.json();",
                  "  if (body && body.orderId) pm.environment.set('orderId', body.orderId);",
                  "  if (body && body.checkoutUrl) pm.environment.set('checkoutUrl', body.checkoutUrl);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cartId\": \"{{cartId}}\"\n}"
            },
            "url": "{{baseUrl}}/checkout"
          }
        },
        {
          "name": "Webhook Endpoint (manual debug)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"Use Stripe CLI instead: stripe listen --forward-to localhost:18080/checkout/webhook\"\n}"
            },
            "url": "{{baseUrl}}/checkout/webhook"
          }
        }
      ]
    },
    {
      "name": "5 - Orders",
      "item": [
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "Get Order By ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        }
      ]
    },
    {
      "name": "6 - Users",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"email\": \"{{userEmail}}\"\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"{{userPassword}}\",\n  \"newPassword\": \"newpassword123\"\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}/change-password"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        }
      ]
    },
    {
      "name": "7 - Admin",
      "item": [
        {
          "name": "Admin Hello",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/admin/hello"
          }
        }
      ]
    }
  ]
}
